digraph PandaSubmission {
    rankdir=LR;
    node [shape=box, style=rounded];

    // Clusters for different environments
    subgraph cluster_local {
        label="Local Machine";
        style=filled;
        color=lightgrey;

        csv [label="CSV file\n(job list)"];
        scripts [label="submit_csv.sh\nsubmit_panda_api.py"];
        workdir [label="Work directory\n(submit_panda.py\nenvironment.sh, etc)"];
        tarball [label="jobO.*.tar.gz\n(created locally)"];

        csv -> scripts [label="parse"];
        workdir -> tarball [label="tar.gz"];
        scripts -> tarball [label="create"];
    }

    subgraph cluster_panda {
        label="PanDA Server";
        style=filled;
        color=lightblue;

        cache [label="PanDA Cache\n/cache/jobO.*.tar.gz"];
        jedi [label="PanDA JEDI\n(task → jobs)"];
        taskparams [label="Task Parameters\nsourceURL\nnEvents\njobParameters"];

        cache -> jedi [label="reference"];
        taskparams -> jedi [label="process"];
    }

    subgraph cluster_worker {
        label="Worker Node";
        style=filled;
        color=lightgreen;

        pilot [label="PanDA Pilot"];
        rungen [label="runGen Transformation\nrunGen-00-00-02"];
        container [label="Singularity Container\neic_xl:nightly"];
        exec_script [label="__run_main_exec.sh\n(generated by runGen)"];
        user_code [label="User Code\nsubmit_panda.py"];
        output [label="Output Files\n*.log.tgz"];

        pilot -> rungen [label="execute"];
        rungen -> container [label="--preprocess\n(download tarball\nextract files)"];
        container -> exec_script [label="generate"];
        exec_script -> user_code [label="execute:\npython3 submit_panda.py <N>"];
        user_code -> output [label="produce"];
        output -> pilot [label="--postprocess\n(upload)"];
    }

    // Cross-cluster connections
    tarball -> cache [label="Client.putFile()\nupload"];
    scripts -> taskparams [label="client.submit_task()"];
    jedi -> pilot [label="job assignment"];
    cache -> rungen [label="download\n${SURL}/cache/jobO.*.tar.gz"];

    // Template variable substitutions
    subgraph cluster_templates {
        label="Template Variable Substitutions";
        style=dashed;
        color=orange;

        t1 [shape=note, label="Client side:\n%RNDM=0 → ${SEQNUMBER}"];
        t2 [shape=note, label="JEDI side:\n${SURL} → https://pandaserver...\n${SEQNUMBER} → 0,1,2,..."];
        t3 [shape=note, label="runGen side:\n$(SN) → serial number"];

        t1 -> scripts [style=dotted];
        t2 -> jedi [style=dotted];
        t3 -> rungen [style=dotted];
    }

    // Key jobParameters flow
    jp [shape=note, label="jobParameters:\n-j \"\" --sourceURL ${SURL}\n-r .\n-a jobO.*.tar.gz\n-p \"python3 submit_panda.py ${SEQNUMBER}\""];
    jp -> taskparams [style=dotted, color=red];
}
