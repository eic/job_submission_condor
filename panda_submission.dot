digraph PandaSubmission {
    rankdir=TB;
    node [shape=box, style=rounded];

    // Clusters for different environments
    subgraph cluster_local {
        label="Local Machine";
        style=filled;
        color=lightgrey;

        web [label="Web Archive / Local\n(CSV source + timing data)"];
        bg_repo [label="Background Config Repo\n(BG_FILES json)"];
        csv_chunk [label="csv_to_chunks.sh\nDownload & chunk\nbased on target hours"];
        csv [label="CSV file\n(chunked job definitions)"];
        bg_files [label="BG_FILES json\n(downloaded if needed)"];
        scripts [label="submit_csv.sh\nsubmit_panda_api.py"];
        workdir [label="Work directory\n(submit_panda.py\nrun.sh\nenvironment.sh\nBG_FILES json)"];
        tarball [label="jobO.*.tar.gz\n(created locally)"];
        dataset [label="Dataset Name\n${RUCIO_SCOPE}.${DETECTOR_VERSION}.\n${DETECTOR_CONFIG}.${TAG_PREFIX}...", shape=note, color=yellow];

        web -> csv_chunk [label="fetch if CSV_FILE not set"];
        bg_repo -> bg_files [label="curl -L -O\nif BG_FILES set"];
        csv_chunk -> csv [label="chunk by\ntarget hours"];
        csv -> scripts [label="parse\ncount jobs"];
        bg_files -> workdir [label="include"];
        workdir -> tarball [label="tar.gz"];
        scripts -> tarball [label="create"];
        scripts -> dataset [label="construct", style=dotted];
    }

    subgraph cluster_panda {
        label="PanDA Server";
        style=filled;
        color=lightblue;

        cache [label="PanDA Cache\n/cache/jobO.*.tar.gz"];
        jedi [label="PanDA JEDI\n(task → jobs)"];
        taskparams [label="Task Parameters\nsourceURL\nnEvents\njobParameters"];

        cache -> jedi [label="reference"];
        taskparams -> jedi [label="process"];
    }

    subgraph cluster_worker {
        label="Worker Node";
        style=filled;
        color=lightgreen;

        pilot [label="PanDA Pilot"];
        rungen [label="runGen Transformation\nrunGen-00-00-02"];
        container [label="Singularity Container\neic_xl:${JUG_XL_TAG}"];
        exec_script [label="__run_main_exec.sh\n(generated by runGen)"];
        submit_panda [label="submit_panda.py\nReads CSV row n-1"];
        run_sh [label="run.sh\n1. BG mixing (SignalBackgroundMerger)\n2. Simulation (npsim)\n3. Reconstruction (eicrecon)"];
        output [label="Output Files\nLOG: $JEDITASKID.$SN.log.tgz\nRECO: *.eicrecon.edm4eic.root\nFULL: *.edm4hep.root"];
        rucio [label="Rucio Storage\n(if USERUCIO=true)"];

        pilot -> rungen [label="execute"];
        rungen -> container [label="--preprocess\n(download tarball\nextract files)"];
        container -> exec_script [label="generate"];
        exec_script -> submit_panda [label="python3 submit_panda.py ${SEQNUMBER}\n(SEQNUMBER: 1,2,3...)"];
        submit_panda -> run_sh [label="call with CSV params\n(EBEAM, PBEAM, BG_FILES,\nSIGNAL_*, etc.)"];
        run_sh -> output [label="produce"];
        output -> rucio [label="register & upload\n(COPYRECO, COPYFULL, COPYLOG)"];
        rucio -> pilot [label="--postprocess\ncomplete"];
    }

    // Cross-cluster connections
    tarball -> cache [label="Client.putFile()\nupload"];
    scripts -> taskparams [label="client.submit_task()"];
    jedi -> pilot [label="job assignment"];
    cache -> rungen [label="download\n${SURL}/cache/jobO.*.tar.gz"];

    // Environment variable flow
    subgraph cluster_env {
        label="Environment Variables & Parameters";
        style=dashed;
        color=orange;

        env1 [shape=note, label="submit_csv.sh environment:\nEBEAM, PBEAM\nDETECTOR_VERSION, DETECTOR_CONFIG\nSIGNAL_FREQ, SIGNAL_STATUS\nBG_FILES, TAG_PREFIX\nCOPYRECO, COPYFULL, COPYLOG"];
        env2 [shape=note, label="Template substitution:\n%RNDM=0 → ${SEQNUMBER}\n${SEQNUMBER} → 1,2,3,... (JEDI)\n$JEDITASKID → task ID (JEDI)\n${SN} → serial number"];
        env3 [shape=note, label="Worker execution:\nsubmit_panda.py: SEQNUMBER → CSV row (n-1)\nrun.sh: Uses environment vars\nfrom environment.sh"];

        env1 -> scripts [style=dotted];
        env2 -> jedi [style=dotted];
        env3 -> submit_panda [style=dotted];
    }

    // Key jobParameters flow
    jp [shape=note, label="jobParameters:\n-j \"\" --sourceURL ${SURL}\n-r .\n-a jobO.*.tar.gz\n-p \"python3 submit_panda.py ${SEQNUMBER}\""];
    jp -> taskparams [style=dotted, color=red];
}
